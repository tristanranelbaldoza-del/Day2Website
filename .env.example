# Template showing which environment variables this project expects.
# Copy this file to `.env` and fill in real values. `.env` is gitignored;
# `.env.example` is safe to commit (no real secrets).

# Kie.ai API key — used to generate videos via Veo 3 / Runway / Kling.
# Get yours at https://kie.ai/dashboard
KIE_API_KEY=your_kie_api_key_here

# Resend MCP — lets the Resend MCP server (configured in .mcp.json) send
# email via your Resend account. Sign up at https://resend.com to get a
# key, then verify a sending domain before you can use custom From addresses.
RESEND_API_KEY=re_your_resend_api_key_here
SENDER_EMAIL_ADDRESS=hello@yourdomain.com
REPLY_TO_EMAIL_ADDRESSES=you@yourdomain.com

# Supabase — if you want to route the contact form to Supabase (Postgres)
# instead of / alongside Google Sheets. Create a project at
# https://supabase.com/ and copy these from Project Settings → API.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_public_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Firecrawl MCP — lets the Firecrawl MCP server (configured in .mcp.json)
# scrape, crawl, search, and extract from the web. Get a key at
# https://www.firecrawl.dev/app/api-keys
FIRECRAWL_API_KEY=fc-your_firecrawl_api_key_here
