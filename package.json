{
  "name": "tester-io-site",
  "version": "1.0.0",
  "description": "Tester.io landing page + contact form backend",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "static": "node serve.mjs",
    "test": "playwright test",
    "test:chromium": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:report": "playwright show-report"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.104.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "ffmpeg-static": "^5.3.0",
    "googleapis": "^171.4.0",
    "imapflow": "^1.3.2",
    "mailparser": "^3.9.8",
    "nodemailer": "^8.0.5",
    "puppeteer": "^24.42.0",
    "resend": "^6.12.2",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "supabase": "^2.95.0"
  }
}
